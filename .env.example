# ---- Base de datos / Auth (Supabase recomendado) ----
SUPABASE_URL=                       # usado por netlify/functions/* (service role)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # solo en funciones serverless, nunca en frontend

# ---- Mismas credenciales, expuestas al frontend Next.js ----
# NEXT_PUBLIC_* se compila dentro del bundle del navegador: solo la URL y la
# anon key (nunca la service role key) van aquí. Deben apuntar al mismo
# proyecto que SUPABASE_URL/SUPABASE_ANON_KEY de arriba.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Almacenamiento de adjuntos (protocolo S3, cualquier proveedor
# compatible — Supabase Storage en modo S3, Cloudflare R2, AWS S3 real) ----
# Usado por netlify/functions/_shared/s3Client.ts para los adjuntos de
# messages-send.ts (salientes) y gmail-poll.ts (entrantes). Ver SETUP.md
# sección 3 para cómo obtener estos valores en Supabase Storage.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SIGNED_URL_EXPIRY_SECONDS=900
# Endpoint del proveedor S3-compatible — copiarlo tal cual del dashboard de
# Supabase Storage (Project Settings → Storage → S3 Connection). Solo se
# omite si usas AWS S3 real (el SDK ya sabe armar el endpoint por región).
S3_ENDPOINT=

# ---- Correo transaccional (envío) ----
TRANSACTIONAL_EMAIL_PROVIDER=       # postmark | sendgrid | brevo
TRANSACTIONAL_EMAIL_API_KEY=
TRANSACTIONAL_EMAIL_FROM=notificaciones@erplawyers.com

# ---- OAuth de buzones de usuario (Google Workspace / Microsoft 365) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://<tu-dominio>/.netlify/functions/oauth-google-callback
MS365_OAUTH_CLIENT_ID=
MS365_OAUTH_CLIENT_SECRET=
MS365_OAUTH_REDIRECT_URI=https://<tu-dominio>/.netlify/functions/oauth-ms365-callback

# Cifra access_token/refresh_token de buzones_correo antes de guardarlos
# (AES-256-GCM, netlify/functions/_shared/tokenCrypto.ts). Debe decodificar
# a exactamente 32 bytes en base64. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Si se rota, los buzones ya conectados quedan indescifrables y cada
# usuario deberá reconectar su cuenta.
TOKEN_ENCRYPTION_KEY=

# Secreto compartido para netlify/functions/gmail-poll.ts (recibe correo
# entrante nuevo por buzón conectado). No usa sesión de usuario -es un cron
# job- así que se autentica con este valor en el header X-Cron-Secret en vez
# de un Bearer token. Generar con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_POLL_SECRET=

# ---- WhatsApp Business Platform (Meta oficial o BSP autorizado) ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=                # para verificar firma X-Hub-Signature-256

# ---- WordPress ----
WORDPRESS_WEBHOOK_SHARED_SECRET=    # firma HMAC de los formularios entrantes

# ---- Colas / reintentos (Upstash Redis o SQS) ----
QUEUE_PROVIDER=                     # upstash | sqs
QUEUE_CONNECTION_URL=

# ---- Usuarios iniciales (sustituir antes de producción) ----
BAYRON_EMAIL=bayron@erplawyers.com
JUAN_CARLOS_EMAIL=juancarlos@erplawyers.com
JOSE_MARTIN_EMAIL=jose@erplawyers.com
MAISHA_EMAIL=maisha@erplawyers.com
INITIAL_TEMP_PASSWORD=ERPLaw.1122   # forzar cambio en primer ingreso, no reutilizar

# ---- General ----
APP_BASE_URL=https://crm.erplawyers.com
NODE_ENV=production
